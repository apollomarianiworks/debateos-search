# Build artifacts
dist/
node_modules/
src-tauri/target/
src-tauri/gen/schemas/
release/

# Tauri updater signing keys — NEVER commit the private key.
# The public key (.tauri/signing.key.pub) is safe to commit and is also
# embedded into tauri.conf.json (`plugins.updater.pubkey`) for verification.
.tauri/signing.key
.tauri/*.priv
.tauri/dev-signer*

# Local environment
.env
.env.local
.vscode/settings.json
.idea/
.claude/
tmp/
